    "dc_rights": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "dc_subject": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "dc_subject_": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "dc_title": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "dshash": {
      "type": "object"
    },
    "ispartof": {
      "items": {
        "type": "string"
      },
      "type": "array"
