        "type": "string"
      },
      "type": "array"
    },
    "bib_publisher": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "bib_publisherlocation": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "bib_roles_pers_aut": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "cmodel": {
      "type": "string"
    },
