        "type": "string"
      },
      "type": "array"
    },
    "dc_date": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "dc_description": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "dc_description_": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "dc_identifier": {
      "items": {
        "type": "string"
      },
      "type": "array"
